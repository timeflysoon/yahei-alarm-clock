{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YaheiAlarmClock",
  "version": "1.0.0",
  "identifier": "com.yahei.alarmclock",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "极简雅黑桌面闹钟",
        "width": 1020,
        "height": 720,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.ico"]
  }
}
