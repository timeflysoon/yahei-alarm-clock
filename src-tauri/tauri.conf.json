{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YaheiAlarmClock",
  "version": "1.0.0",
  "identifier": "com.yahei.alarmclock",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../ui"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; media-src 'self' https://clockcn.com https://www.soundhelix.com https://www.naobiao.com; font-src 'self' https://cdn.jsdelivr.net"
    },
    "windows": [
      {
        "title": "极简雅黑桌面闹钟",
        "width": 720,
        "height": 550,
        "resizable": false,
        "transparent": false,
        "decorations": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.ico"],
    "resources": []
  }
}
